# ===========================================
# 穆氏家谱系统 - 环境配置示例
# ===========================================
# 请复制此文件为 .env 并填入实际值
# cp .env.example .env

# -------------------------------------------
# 基础配置
# -------------------------------------------

# 服务器端口
PORT=3003

# 运行环境: development / production
NODE_ENV=development

# JWT 密钥（生产环境请使用安全的随机字符串）
# 可使用命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_secure_jwt_secret_key_here

# -------------------------------------------
# 数据库配置（PostgreSQL）- 必填
# -------------------------------------------
# 本项目统一使用 PostgreSQL + Prisma 作为数据库
# 本地开发和 Vercel 生产环境使用相同的数据库配置
#
# 推荐使用 Neon (https://neon.tech) 免费 Serverless PostgreSQL
# 1. 访问 https://neon.tech 注册账号
# 2. 创建新项目，获取连接字符串
# 3. Neon 会提供两个连接地址：
#    - DATABASE_URL: 连接池地址（用于应用连接）
#    - DATABASE_URL_UNPOOLED: 直连地址（用于 Prisma 迁移）

# 主连接字符串（使用连接池）
DATABASE_URL=postgresql://username:password@hostname/database?sslmode=require

# 直接连接字符串（用于数据库迁移）
DATABASE_URL_UNPOOLED=postgresql://username:password@hostname/database?sslmode=require

# -------------------------------------------
# 前端配置
# -------------------------------------------

# API 基础地址（开发环境）
REACT_APP_API_BASE_URL=http://localhost:3003

# 环境标识
REACT_APP_ENV=development

# 调试模式
REACT_APP_DEBUG=true

# -------------------------------------------
# 多租户配置
# -------------------------------------------

# 默认租户 ID
REACT_APP_DEFAULT_TENANT_ID=default

# 启用多租户功能
REACT_APP_ENABLE_MULTI_TENANT=true

# -------------------------------------------
# 阿里云通义千问 API（可选 - 用于 OCR 功能）
# -------------------------------------------
# 申请地址: https://dashscope.console.aliyun.com/

REACT_APP_QWEN_API_KEY=your_qwen_api_key_here

# -------------------------------------------
# 阿里云 OSS 配置（可选 - 用于图片上传）
# -------------------------------------------
# 申请地址: https://oss.console.aliyun.com/

# OSS 区域
# 可选值: oss-cn-hangzhou, oss-cn-shanghai, oss-cn-beijing 等
REACT_APP_OSS_REGION=oss-cn-hangzhou

# OSS 存储桶名称
REACT_APP_OSS_BUCKET=your-bucket-name

# 阿里云 AccessKey
REACT_APP_OSS_ACCESS_KEY_ID=your_oss_access_key_id
REACT_APP_OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret

# OSS 自定义域名（可选）
# REACT_APP_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# -------------------------------------------
# 邮件服务配置（可选 - 用于发送验证码）
# -------------------------------------------

# SMTP 服务器配置
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password

# -------------------------------------------
# Redis 配置（可选 - 用于缓存）
# -------------------------------------------

# REDIS_URL=redis://localhost:6379

# -------------------------------------------
# OSS 区域对照表
# -------------------------------------------
# 华东1（杭州）: oss-cn-hangzhou
# 华东2（上海）: oss-cn-shanghai
# 华北1（青岛）: oss-cn-qingdao
# 华北2（北京）: oss-cn-beijing
# 华北3（张家口）: oss-cn-zhangjiakou
# 华南1（深圳）: oss-cn-shenzhen
# 西南1（成都）: oss-cn-chengdu
# 中国香港: oss-cn-hongkong
# 新加坡: oss-ap-southeast-1
# 日本: oss-ap-northeast-1
