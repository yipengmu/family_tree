# ===========================================
# 谱里数字家谱 - 环境配置示例
# ===========================================
# 请复制此文件为 .env 并填入实际值
# cp .env.example .env

# -------------------------------------------
# 基础配置
# -------------------------------------------

# 本地 API 服务端口（前端开发服务器由 npm run dev 固定使用 3000）
SERVER_PORT=3003

# 运行环境: development / production
NODE_ENV=development

# JWT 密钥（生产环境请使用安全的随机字符串）
# 可使用命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_secure_jwt_secret_key_here

# -------------------------------------------
# 数据库配置（PostgreSQL）- 必填
# -------------------------------------------
# 本项目统一使用 PostgreSQL + Prisma 作为数据库
# 本地开发和 Vercel 生产环境使用相同的数据库配置
#
# 推荐使用 Neon (https://neon.tech) 免费 Serverless PostgreSQL
# 1. 访问 https://neon.tech 注册账号
# 2. 创建新项目，获取连接字符串
# 3. Neon 会提供两个连接地址：
#    - DATABASE_URL: 连接池地址（用于应用连接）
#    - DATABASE_URL_UNPOOLED: 直连地址（用于 Prisma 迁移）

# 主连接字符串（使用连接池）
DATABASE_URL=postgresql://username:password@hostname/database?sslmode=require

# 直接连接字符串（用于数据库迁移）
DATABASE_URL_UNPOOLED=postgresql://username:password@hostname/database?sslmode=require

# -------------------------------------------
# 前端配置
# -------------------------------------------

# API 基础地址（开发环境）
REACT_APP_API_BASE_URL=http://localhost:3003

# 环境标识
REACT_APP_ENV=development

# 调试模式
REACT_APP_DEBUG=true

# PostHog 产品分析（仅使用公开 project key；不上传个人信息或家谱内容）
# 推荐在 PostHog 中选择 EU (Frankfurt) 项目区域
REACT_APP_POSTHOG_KEY=
REACT_APP_POSTHOG_HOST=https://eu.i.posthog.com

# -------------------------------------------
# 多租户配置
# -------------------------------------------

# 默认租户 ID
REACT_APP_DEFAULT_TENANT_ID=default

# 启用多租户功能
REACT_APP_ENABLE_MULTI_TENANT=true

# -------------------------------------------
# 腾讯云配置（COS、ASR、TokenHub 多模态解析、邮件）
# -------------------------------------------
# 统一使用服务端密钥；不要添加 REACT_APP_ 前缀。
TENCENTCLOUD_SECRET_ID=your_tencent_secret_id_here
TENCENTCLOUD_SECRET_KEY=your_tencent_secret_key_here

# COS 私有桶（广州、单 AZ、标准存储、SSE-COS）
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=your-cos-bucket-appid

# 腾讯云 ASR
TENCENT_ASR_REGION=ap-guangzhou
TENCENT_ASR_ENGINE=16k_zh

# TokenHub（纸质家谱图片直接使用 hy-vision-2.0-instruct，不前置传统 OCR）
TENCENT_TOKENHUB_API_KEY=your_tokenhub_api_key_here
TENCENT_TOKENHUB_BASE_URL=https://tokenhub.tencentmaas.com/v1
TENCENT_STORY_MODEL=hy3
TENCENT_VISION_MODEL=hy-vision-2.0-instruct

# 腾讯云邮件推送 SES（用于发送注册/重置验证码和邀请）
TENCENT_SES_REGION=ap-guangzhou
TENCENT_SES_FROM_EMAIL=your_ses_from_email@example.com
TENCENT_SES_TEMPLATE_ID=your_template_id_here
TENCENT_SES_SUBJECT=数字家谱验证码
TENCENT_SES_INVITATION_TEMPLATE_ID=your_invitation_template_id_here
TENCENT_SES_INVITATION_SUBJECT=邀请你一起续写家谱

# -------------------------------------------
# Redis 配置（可选 - 用于缓存）
# -------------------------------------------

# REDIS_URL=redis://localhost:6379

# 公共应用地址（邀请链接，可选）
PUBLIC_APP_URL=http://localhost:3000
