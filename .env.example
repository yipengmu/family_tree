# 环境配置示例文件
# 请复制此文件为 .env 并填入实际值

# 服务器端口
PORT=3003

# JWT密钥 - 请使用安全的随机字符串
JWT_SECRET=your_secure_jwt_secret_key_here

# 数据库配置 - Neon无服务器数据库
DATABASE_URL=postgresql://neondb_owner:npg_pL9ETAsj3Xau@ep-orange-hill-a1xbvqot-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# 用于直接连接（不使用连接池）
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:npg_pL9ETAsj3Xau@ep-orange-hill-a1xbvqot.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Neon数据库参数
PGHOST=ep-orange-hill-a1xbvqot-pooler.ap-southeast-1.aws.neon.tech
PGHOST_UNPOOLED=ep-orange-hill-a1xbvqot.ap-southeast-1.aws.neon.tech
PGUSER=neondb_owner
PGDATABASE=neondb
PGPASSWORD=npg_pL9ETAsj3Xau

# 用于Vercel Postgres模板
POSTGRES_URL=postgresql://neondb_owner:npg_pL9ETAsj3Xau@ep-orange-hill-a1xbvqot-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://neondb_owner:npg_pL9ETAsj3Xau@ep-orange-hill-a1xbvqot.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
POSTGRES_USER=neondb_owner
POSTGRES_HOST=ep-orange-hill-a1xbvqot-pooler.ap-southeast-1.aws.neon.tech
POSTGRES_PASSWORD=npg_pL9ETAsj3Xau
POSTGRES_DATABASE=neondb
POSTGRES_URL_NO_SSL=postgresql://neondb_owner:npg_pL9ETAsj3Xau@ep-orange-hill-a1xbvqot-pooler.ap-southeast-1.aws.neon.tech/neondb
POSTGRES_PRISMA_URL=postgresql://neondb_owner:npg_pL9ETAsj3Xau@ep-orange-hill-a1xbvqot-pooler.ap-southeast-1.aws.neon.tech/neondb?connect_timeout=15&sslmode=require

# 参数用于构建自己的连接字符串
NEXT_PUBLIC_STACK_PROJECT_ID=****************************
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=****************************************
STACK_SECRET_SERVER_KEY=***********************​

# 应用配置
NODE_ENV=production

# Redis配置（可选）
# REDIS_URL=redis://localhost:6379

# 邮件服务配置（可选）
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password

# 千问API密钥
REACT_APP_QWEN_API_KEY=your_qwen_api_key_here

# 开发环境配置
REACT_APP_ENV=development
REACT_APP_DEBUG=true

# 多租户配置
REACT_APP_DEFAULT_TENANT_ID=default
REACT_APP_ENABLE_MULTI_TENANT=true



# 阿里云通义千问API配置
REACT_APP_QWEN_API_KEY=your_qwen_api_key

# 阿里云OSS配置 (必需 - 请取消注释并填写真实值)
REACT_APP_OSS_REGION=oss-cn-hangzhou
REACT_APP_OSS_BUCKET=your-bucket-name
REACT_APP_OSS_ACCESS_KEY_ID=your_oss_access_key_id
REACT_APP_OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
# REACT_APP_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com  # 可选

# OSS配置说明:
# - region: OSS区域，如 oss-cn-hangzhou, oss-cn-beijing 等
# - bucket: OSS存储桶名称
# - accessKeyId: 阿里云AccessKey ID
# - accessKeySecret: 阿里云AccessKey Secret  
# - endpoint: OSS访问域名，可选，不填则使用默认域名

# OSS区域对照表:
# 华东1（杭州）: oss-cn-hangzhou
# 华东2（上海）: oss-cn-shanghai  
# 华北1（青岛）: oss-cn-qingdao
# 华北2（北京）: oss-cn-beijing
# 华北3（张家口）: oss-cn-zhangjiakou
# 华南1（深圳）: oss-cn-shenzhen
# 西南1（成都）: oss-cn-chengdu
# 中国香港: oss-cn-hongkong
# 美国西部1（硅谷）: oss-us-west-1
# 美国东部1（弗吉尼亚）: oss-us-east-1
# 亚太东南1（新加坡）: oss-ap-southeast-1
# 亚太东南2（悉尼）: oss-ap-southeast-2
# 亚太东南3（吉隆坡）: oss-ap-southeast-3
# 亚太东南5（雅加达）: oss-ap-southeast-5
# 亚太东北1（日本）: oss-ap-northeast-1
# 亚太南部1（孟买）: oss-ap-south-1
# 欧洲中部1（法兰克福）: oss-eu-central-1
# 英国（伦敦）: oss-eu-west-1
# 中东东部1（迪拜）: oss-me-east-1
