{
  "version": 2,
  "installCommand": "npm ci --prefer-offline --no-audit --no-fund",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "build",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
