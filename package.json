    "start:proxy": "node start-with-proxy.js",
    "cors-proxy": "node cors-proxy-server.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "vercel-build": "npm run build",
